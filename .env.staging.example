# Staging overrides for tooling that targets the staging environment.
# Copy this file to .env.staging and fill in the values.
# DO NOT commit .env.staging — it contains credentials.
#
# Today staging shares the production WordPress backend, so the WP_* keys
# usually mirror .env.production. Once staging gets its own WP backend,
# point them at the staging cms.* host instead.

# CMS API credentials — read by scripts/cdcf_api.py when invoked with
# `--target staging`. Same key names as .env.local / .env.production.
WP_REST_URL=https://cms.catholicdigitalcommons.org/wp-json
WP_GRAPHQL_URL=https://cms.catholicdigitalcommons.org/graphql
WP_APP_USERNAME=
WP_APP_PASSWORD=
WP_PREVIEW_SECRET=

# Staging Next.js base URL (the public staging frontend, no trailing slash)
NEXTJS_URL=
