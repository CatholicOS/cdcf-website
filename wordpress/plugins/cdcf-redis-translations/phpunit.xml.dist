<?xml version="1.0"?>
<phpunit
    bootstrap="tests/bootstrap.php"
    colors="true"
    cacheDirectory=".phpunit.cache"
    failOnWarning="true"
    failOnNotice="true"
>
    <testsuites>
        <testsuite name="cdcf-redis-translations">
            <directory>tests</directory>
        </testsuite>
    </testsuites>
</phpunit>
