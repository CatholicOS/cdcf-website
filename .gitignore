# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
# PHPUnit coverage outputs (one per WordPress tree)
wordpress/plugins/*/coverage.xml
wordpress/themes/*/coverage.xml

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore everything except .example templates
.env
.env.*
!.env.*.example
# also catch vim swap files for the above
.*.env.*.sw?
..env.*.sw?

# vercel
.vercel

# python
.venv/
__pycache__/

# typescript
*.tsbuildinfo
next-env.d.ts

# dev scripts
.dev.log
.dev.pid

# zitadel
.zitadel-data/

# disposable email domain blocklist (downloaded daily by worker)
wordpress/themes/cdcf-headless/disposable-domains.txt
