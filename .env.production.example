# Production overrides for tooling that targets the live site.
# Copy this file to .env.production and fill in the values.
# DO NOT commit .env.production — it contains credentials.

# SSH connection (used by db-sync scripts)
PROD_SSH_USER=
PROD_SSH_HOST=
PROD_SSH_KEY=

# WordPress installation path on production server
PROD_WP_PATH=

# Production database credentials (find these in wp-config.php on the server)
PROD_DB_NAME=
PROD_DB_USER=
PROD_DB_PASSWORD=
PROD_DB_PREFIX=

# Production site URL (no trailing slash)
PROD_SITE_URL=

# CMS API credentials — read by scripts/cdcf_api.py when invoked with
# `--target production`. Same key names as .env.local but pointing at
# the live WordPress + Next.js, and using the production Application
# Password and WP_PREVIEW_SECRET (which differ from the local ones).
WP_REST_URL=https://cms.catholicdigitalcommons.org/wp-json
WP_GRAPHQL_URL=https://cms.catholicdigitalcommons.org/graphql
WP_APP_USERNAME=
WP_APP_PASSWORD=
WP_PREVIEW_SECRET=
NEXTJS_URL=https://catholicdigitalcommons.org
