# Production database sync configuration
# Copy this file to .env.production and fill in the values.
# DO NOT commit .env.production — it contains credentials.

# SSH connection
PROD_SSH_USER=
PROD_SSH_HOST=
PROD_SSH_KEY=

# WordPress installation path on production server
PROD_WP_PATH=

# Production database credentials (find these in wp-config.php on the server)
PROD_DB_NAME=
PROD_DB_USER=
PROD_DB_PASSWORD=
PROD_DB_PREFIX=

# Production site URL (no trailing slash)
PROD_SITE_URL=
