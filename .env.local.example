# WordPress endpoints — host-perspective by default so `npm run dev` and the
# Python client (scripts/cdcf_api.py) work without extra mapping. When the
# Next.js container is enabled via `docker compose --profile production up`,
# docker-compose.yml overrides these to the container-perspective values
# (http://wordpress/...) for that service only.
WP_GRAPHQL_URL=http://localhost:8000/graphql

# Shared secret for draft-mode preview + cache revalidation. Consumed by BOTH
# sides and must match, or preview/revalidate returns 401:
#   - Next.js validates it on /api/preview and /api/revalidate
#   - the WordPress container reads it too (docker-compose passes it in; the
#     theme falls back to getenv('WP_PREVIEW_SECRET') when CDCF_PREVIEW_SECRET
#     is not defined in wp-config). Docker substitutes it from .env, so set the
#     same value there as well, not only in .env.local.
WP_PREVIEW_SECRET=

# WordPress admin credentials (used by wp-init auto-setup)
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@cdcf.dev

# WordPress database credentials
WP_DB_ROOT_PASSWORD=
WP_DB_NAME=wordpress
WP_DB_USER=wordpress
WP_DB_PASSWORD=

# OpenAI API key for automatic content translation during init (optional)
# If set, all pages and CPT entries are translated into all Polylang languages.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# WordPress REST API (Application Password auth)
# Used for publishing content via the REST API
# Generate an Application Password in WP Admin → Users → Profile → Application Passwords
WP_REST_URL=http://localhost:8000/wp-json
WP_APP_USERNAME=
WP_APP_PASSWORD=

# GitHub personal access token (optional — increases API rate limit from 60 to 5000 req/hr)
# Used for fetching repository language data on project detail pages
GITHUB_TOKEN=

# SMTP configuration for wp_mail() (optional — falls back to PHP mail if unset)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=

# Zitadel OIDC (Auth.js v5 — see lib/auth.ts)
# AUTH_ZITADEL_ID + AUTH_ZITADEL_SECRET are produced by
# cdcf-infra's `setup-zitadel.sh --provision-cdcf-website` handoff
# (see auth/handoffs/cdcf-website.md in cdcf-infra). The secret is
# emitted ONCE at provisioning — capture it then.
#
# IMPORTANT: the CDCF Org provisions TWO confidential apps (one for
# production, one for non-production), each minting tokens with its
# own AUTH_ZITADEL_ID / aud claim. On the SHARED WordPress backend,
# wp-config.php must define CDCF_ZITADEL_EXPECTED_AUD as a comma-
# separated allow-list of BOTH client IDs — otherwise the bearer
# validator will 403 tokens from whichever frontend is missing from
# the constant. Each frontend's .env.* file still pins its own
# AUTH_ZITADEL_ID (the one its sign-in flow uses). See the "Zitadel
# bearer authentication" section of AGENTS.md for the full shape.
AUTH_ZITADEL_ID=
AUTH_ZITADEL_SECRET=
AUTH_ZITADEL_ISSUER=https://auth.catholicdigitalcommons.org

# Auth.js session encryption key. Generate per-environment with:
#   openssl rand -base64 32
# Different value per env (prod / staging / dev); never share between them.
AUTH_SECRET=
